<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp"
            android:elevation="1dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Edit Profile"
                android:textColor="#1A1D29"
                android:textSize="17sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Avatar section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@android:color/white"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    app:cardCornerRadius="44dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/iv_profile_picture"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_person_placeholder"
                        android:background="#EEF1FA" />

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#2F6FED">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="6dp"
                        android:src="@drawable/ic_camera"
                        app:tint="@android:color/white" />

                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_change_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Change photo"
                android:textColor="#2F6FED"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Personal info card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="PERSONAL INFO"
            android:textColor="#9CA3AF"
            android:textSize="11.5sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gender"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinner_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#F0F1F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Birthday"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_edit_birthday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="DD/MM/YYYY"
                    android:focusable="false"
                    android:clickable="true"
                    android:textColor="#1A1D29"
                    android:textColorHint="#C4C8D2"
                    android:textSize="15sp"
                    android:paddingVertical="6dp"
                    tools:text="14/3/2003" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#F0F1F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="University"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_edit_university"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="e.g. Universiti Malaya"
                    android:inputType="text"
                    android:textColor="#1A1D29"
                    android:textColorHint="#C4C8D2"
                    android:textSize="15sp"
                    android:paddingVertical="6dp"
                    tools:text="Universiti Malaya" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Education & experience card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="EDUCATION &amp; EXPERIENCE"
            android:textColor="#9CA3AF"
            android:textSize="11.5sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Education Level"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/spinner_education"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#F0F1F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qualification"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_edit_qualification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="e.g. Bachelor of Computer Science"
                    android:inputType="text"
                    android:textColor="#1A1D29"
                    android:textColorHint="#C4C8D2"
                    android:textSize="15sp"
                    android:paddingVertical="6dp"
                    tools:text="Bachelor of Computer Science" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#F0F1F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Experience"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_edit_experience"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="Briefly describe your experience"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textColor="#1A1D29"
                    android:textColorHint="#C4C8D2"
                    android:textSize="14.5sp"
                    android:paddingVertical="6dp"
                    tools:text="6-month internship as a mobile developer at a fintech startup." />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Skills card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"
            android:text="SKILLS"
            android:textColor="#9CA3AF"
            android:textSize="11.5sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hard Skills"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_edit_hard_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="e.g. Java, SQL, Figma"
                    android:inputType="text"
                    android:textColor="#1A1D29"
                    android:textColorHint="#C4C8D2"
                    android:textSize="15sp"
                    android:paddingVertical="6dp"
                    tools:text="Java, SQL, Figma" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp"
                    android:background="#F0F1F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Soft Skills"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/et_edit_soft_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@null"
                    android:hint="e.g. Communication, Teamwork"
                    android:inputType="text"
                    android:textColor="#1A1D29"
                    android:textColorHint="#C4C8D2"
                    android:textSize="15sp"
                    android:paddingVertical="6dp"
                    tools:text="Communication, Teamwork" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Save / Cancel buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="32dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0F1F5">

                <TextView
                    android:id="@+id/btn_cancel_edit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="15dp"
                    android:text="Cancel"
                    android:textColor="#1A1D29"
                    android:textSize="15.5sp"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#2F6FED">

                <TextView
                    android:id="@+id/btn_save_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="15dp"
                    android:text="Save"
                    android:textColor="@android:color/white"
                    android:textSize="15.5sp"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>