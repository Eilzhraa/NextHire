<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:elevation="2dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tv_notif_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Application Approved!"
        android:textColor="#1E293B"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_notif_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your application for Android Developer at Google has been approved."
        android:textColor="#64748B"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tv_notif_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today, 2:30 PM"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

</LinearLayout>