<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ... any existing styles/themes you already have ... -->

    <style name="ProfileFieldRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:background">@drawable/bg_field_divider</item>
    </style>

    <style name="ProfileFieldRowLast">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <style name="ProfileFieldLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textColor">#9CA3AF</item>
        <item name="android:textSize">13.5sp</item>
    </style>

    <style name="ProfileFieldValue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1.4</item>
        <item name="android:textColor">#1A1D29</item>
        <item name="android:textSize">13.5sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">end</item>
    </style>

</resources>