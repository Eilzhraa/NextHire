<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.NextHireApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/coral</item>
        <item name="colorPrimaryVariant">@color/ink</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/amber</item>
        <item name="android:statusBarColor">@color/ink</item>
    </style>

    <style name="TextDisplay">
        <item name="android:fontFamily">@font/poppins_semibold</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="TextLabel">
        <item name="android:fontFamily">@font/inter_medium</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextBody">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/muted</item>
    </style>

</resources>